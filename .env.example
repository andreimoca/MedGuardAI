# Local LLM Configuration (LM Studio)
# Make sure LM Studio is running on this URL with Gemma-3-4b loaded
LOCAL_LLM_URL=http://127.0.0.1:1234/v1
LOCAL_LLM_MODEL=gemma-3-4b

# Builder/judge LLM. OpenAI-compatible API used by
# backend/training/build_qa_dataset.py (to rewrite MedQuAD answers into
# MedGuardAI's safety-first style + a faithfulness judge against the original
# answer) and by backend/evaluation as the LLM judge. Default points at DeepSeek.
# If unset, these fall back to LOCAL_LLM_URL.
DATASET_LLM_URL=https://api.deepseek.com/v1
DATASET_LLM_KEY=
DATASET_LLM_MODEL=deepseek-chat

# build_qa_dataset.py downloads the MedQuAD dataset from Kaggle via `kagglehub`.
# The dataset is public; if Kaggle prompts for credentials, set these (or place
# a kaggle.json in ~/.kaggle/). Leave blank otherwise.
KAGGLE_USERNAME=
KAGGLE_KEY=
