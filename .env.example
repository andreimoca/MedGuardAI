# Local LLM Configuration (LM Studio)
# Make sure LM Studio is running on this URL with Gemma-3-4b loaded
LOCAL_LLM_URL=http://127.0.0.1:1234/v1
LOCAL_LLM_MODEL=gemma-3-4b

# Dataset-builder LLM (Phase 2). OpenAI-compatible API used by
# backend/training/build_qa_dataset.py. Default points at DeepSeek.
# If unset, the dataset builder falls back to LOCAL_LLM_URL.
DATASET_LLM_URL=https://api.deepseek.com/v1
DATASET_LLM_KEY=
DATASET_LLM_MODEL=deepseek-chat
